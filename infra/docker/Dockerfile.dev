FROM rajim59/python-hardened:latest

USER root

# Development tools: hot reload, linting, and debugging
RUN apk add --no-cache \
    curl \
    git \
    py3-pip \
    && pip install --no-cache-dir \
    uvicorn[standard] \
    watchdog \
    pyflakes \
    black \
    debugpy

# Switch back to the application user
USER appuser
WORKDIR /app

# Copy requirements file from the app directory
COPY --chown=appuser:appgroup app/requirements.txt .
RUN pip install --user --no-cache-dir -r requirements.txt

# Copy application source code from the app directory
COPY --chown=appuser:appgroup app/src/ ./src/

ENV PYTHONUNBUFFERED=1

EXPOSE 8000 5678

# Start Uvicorn in debug mode with hot reload enabled
CMD ["uvicorn", "src.app:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--reload-dir", "/app/src"]